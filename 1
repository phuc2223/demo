<!DOCTYPE html>
<html>
<head>
    <title>Ôn tập</title>

    <style>
        body{
            width: 80%;
            margin: auto;
            font-family: Arial;
            background: linear-gradient(#a0d8ef,#ffd1df);
        }

        .tren{
            width: 100px;
            height: 100px;
            float: left;
            margin: 10px;
            background-color: rgb(56,187,111);
            background-size: 100px 100px;
            border-radius: 12px;
            text-align: center;
            line-height: 100px;
            font-size: 20px;
            color: white;
        }

        h1{
            text-align:center;
        }

        .clear{
            clear: both;
        }
    </style>
</head>

<body>

<h1>Danh sách ô</h1>

<div class="tren">1</div>
<div class="tren">2</div>
<div class="tren">3</div>
<div class="tren">4</div>
<div class="tren">5</div>
<div class="tren">6</div>
<div class="tren">7</div>
<div class="tren">8</div>

<div class="clear"></div>

</body>
</html>
